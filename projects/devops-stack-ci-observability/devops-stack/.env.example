GITEA_ADMIN_PASS=changeme
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASS=changeme

DEV_USER=dev1
DEV_PASS=changeme
CI_USER=ci-bot
CI_PASS=changeme
ORG_NAME=acme
REPO_NAME=demo-app

# Internal URLs (useful for scripts)
GITEA_URL=http://gitea:3000
JENKINS_URL=http://jenkins:8080
SONAR_URL=http://sonarqube:9000
REGISTRY_ADDR=registry:5000
